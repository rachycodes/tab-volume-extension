{
  "manifest_version": 3,
  "name": "Tab Volume Controller",
  "version": "1.0",
  "description": "Control volume for media in different browser tabs.",
  "permissions": ["tabs"],
  "host_permissions": ["<all_urls>"],
  "icons": {
    "48": "icons/icon64.png",
    "128": "icons/icon128.png"
},
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "action": {
    "default_popup": "popup.html"
  }
}